PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Redis (optional - falls back to in-memory cache if unavailable)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300

# Browser
BROWSER_HEADLESS=true
BROWSER_POOL_SIZE=2
BROWSER_TIMEOUT_MS=30000

# Scraper
REQUEST_DELAY_MS=2000
MAX_RETRIES=3

# Proxy (optional - residential proxies recommended for better success rate)
# PROXY_URL=http://user:pass@proxy-host:port

# Rate Limiting
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
